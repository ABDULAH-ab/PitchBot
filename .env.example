LLM_PROVIDER=openai
API_RETRY_DELAY_SECONDS=2

# Role-based model routing (recommended)
CEO_LLM_PROVIDER=gemini
CEO_LLM_MODEL=gemini-3.1-flash-lite-preview
AGENT_LLM_PROVIDER=openai
AGENT_LLM_MODEL=gpt-oss-120b

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=your_openai_model_name

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=your_gemini_model_name

GITHUB_TOKEN=your_github_pat
TARGET_GITHUB_REPO=yourusername/repo_name

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=channel-name

SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=verified_sender@example.com
SENDGRID_TO_EMAIL=you@example.com

REDIS_URL=your_redis_connection_url
